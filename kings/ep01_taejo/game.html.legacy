<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
/* ── Supabase ── */
const SUPA_URL='https://qwsjofkabllbnbsgndun.supabase.co';
const SUPA_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF3c2pvZmthYmxsYm5ic2duZHVuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYxNDc1NTYsImV4cCI6MjA5MTcyMzU1Nn0.2ryUWHRVqNuJ2ylHYr9tvgFwGK_EsVM7KMeuOpgLnks';
const sb=supabase.createClient(SUPA_URL,SUPA_KEY);

/* ── 로그인 상태 확인 (태조편은 누구나 접근 가능) ── */
let currentUser = null;
(async()=>{
  const{data:{session}}=await sb.auth.getSession();
  if(session) currentUser=session.user;
  // 메뉴에 로그인 상태 반영
  updateGameNav();
})();

function updateGameNav(){
  const mw=document.querySelector('.menu-wrap');
  if(!mw)return;
  const loginBtn=document.createElement('button');
  loginBtn.className='menu-item';
  if(currentUser){
    const nick=currentUser.user_metadata?.nickname||currentUser.email.split('@')[0];
    loginBtn.textContent='✨ '+nick+' 님';
    loginBtn.onclick=()=>location.href='../joseon-kings.html';
  }else{
    loginBtn.textContent='로그인 / 회원가입';
    loginBtn.onclick=()=>location.href='../index.html';
  }
  const divider=document.createElement('div');
  divider.className='menu-divider';
  mw.querySelector('.menu-drop')?.prepend(divider);
  mw.querySelector('.menu-drop')?.prepend(loginBtn);
}

// ── 퀴즈 문제 ─────────────────────────────────────────────
const QUIZ=[
  {q:'이성계의 아버지 이름은?',o:['이자겸','이자춘','이인임','이방원'],a:1},
  {q:'이성계 가문은 함경도 어느 지역의 실력자였나?',o:['개경','전주','쌍성','평양'],a:2},
  {q:'원나라가 흔들리기 시작한 이유가 아닌 것은?',o:['황실 권력 싸움','가뭄과 홍수','백성들의 반란','이성계의 저항'],a:3},
  {q:'이성계의 아버지가 공민왕 편으로 돌아선 사건은?',o:['홍건적 격퇴','쌍성총관부 수복','황산대첩','위화도 회군'],a:1},
  {q:'쌍성총관부가 수복된 해는?',o:['1350년','1356년','1362년','1388년'],a:1},
  {q:'이성계와 평생 함께한 여진족 출신 장수는?',o:['이방원','정도전','이지란','최영'],a:2},
  {q:'1361년 홍건적이 침입했을 때 이성계의 병사 수는?',o:['500명','1천명','2천명','5천명'],a:2},
  {q:'홍건적 선봉의 병사 수는?',o:['1천명','2천명','3천명','5천명 이상'],a:3},
  {q:'황산대첩에서 왜구를 이끈 소년 장수는?',o:['아기발도','나하추','탁도경','아지발도'],a:0},
  {q:'황산대첩이 일어난 해는?',o:['1370년','1375년','1380년','1385년'],a:2},
  {q:'이지란이 황산대첩에서 아기발도를 상대한 방법은?',o:['정면 돌파','투구 끈을 화살로 끊어 빈틈을 만들었다','기습 공격','함정을 팠다'],a:1},
  {q:'요동 정벌을 명한 인물은?',o:['이성계','정몽주','최영과 우왕','이방원'],a:2},
  {q:'사불가론에서 이성계가 든 이유가 아닌 것은?',o:['소국이 대국을 거역함','농번기에 군사 동원','병사들의 급여가 부족함','장마철이라 활이 녹음'],a:2},
  {q:'이성계가 회군한 장소는?',o:['압록강','위화도','한강','강화도'],a:1},
  {q:'위화도에서 비가 며칠째 내렸을 때 이성계가 회군을 결정했나?',o:['3일째','5일째','열흘째','보름째'],a:2},
  {q:'개경으로 돌아오는 이성계를 어떻게 맞이했나?',o:['백성들이 막아섰다','백성들이 술과 음식을 들고 마중 나왔다','아무도 없었다','병사들이 반발했다'],a:1},
  {q:'정몽주가 피살된 장소는?',o:['경복궁','선죽교','위화도','개경 저잣거리'],a:1},
  {q:'정몽주를 피살한 사람은?',o:['이성계','정도전','이방원','최영'],a:2},
  {q:'왕자의 난이 일어난 해는?',o:['1392년','1394년','1396년','1398년'],a:3},
  {q:'왕자의 난 이후 이성계가 떠난 곳은?',o:['전주','평양','함경도','강화도'],a:2},
];

// ── 퀴즈 로직 ────────────────────────────────────────────
const QUIZ_TIME_LIMIT = 60; // 제한시간 60초
let quizIdx=0,quizCorrect=0,quizStart=0,quizTimer=null,quizCountdown=null,quizLocked=false;

function startQuiz(){
  quizIdx=0;quizCorrect=0;quizStart=Date.now();quizLocked=false;
  const c=getCurrentScene();if(c>=0)sceneHistory.push(c);
  switchScene(23);
  showQuestion();
  startQuizTimer();
}

function startQuizTimer(){
  clearInterval(quizTimer);
  clearInterval(quizCountdown);

  // 경과 시간 표시 (카운트업)
  quizCountdown=setInterval(()=>{
    const elapsed=(Date.now()-quizStart)/1000;
    const el=document.getElementById('quiz-timer');
    if(el) el.textContent=elapsed.toFixed(1)+'초';
  },100);
}

function showQuestion(){
  const q=QUIZ[quizIdx];
  document.getElementById('quiz-num').textContent='문제 '+(quizIdx+1);
  document.getElementById('quiz-prog-fill').style.width=((quizIdx/20)*100)+'%';
  document.getElementById('quiz-prog-lbl').textContent='퀴즈 '+quizIdx+' / 20';
  document.getElementById('quiz-question').textContent=q.q;
  const cEl=document.getElementById('quiz-choices');
  cEl.innerHTML='';quizLocked=false;
  q.o.forEach((opt,i)=>{
    const btn=document.createElement('button');
    btn.textContent='① ② ③ ④'.split(' ')[i]+'  '+opt;
    btn.style.cssText='width:100%;text-align:left;background:#0a0806;border:1px solid var(--border2);border-radius:6px;padding:12px 15px;color:var(--text2);font-family:\'Noto Serif KR\',serif;font-size:14px;line-height:1.6;cursor:pointer;transition:all .15s;';
    btn.onmouseover=()=>{if(!quizLocked)btn.style.background='#140e08';};
    btn.onmouseout=()=>{if(!quizLocked&&btn.dataset.state!=='correct'&&btn.dataset.state!=='wrong')btn.style.background='#0a0806';};
    btn.onclick=()=>quizPick(i,q.a,btn);
    cEl.appendChild(btn);
  });
}

function quizPick(i,correct,btn){
  if(quizLocked)return;
  if(i===correct){
    quizCorrect++;
    btn.style.background='#081a0a';btn.style.borderColor='var(--green2)';btn.style.color='var(--green3)';
    btn.dataset.state='correct';quizLocked=true;
    setTimeout(nextQuestion,600);
  } else {
    btn.style.background='#1a0806';btn.style.borderColor='var(--red2)';btn.style.color='var(--red3)';
    btn.dataset.state='wrong';quizLocked=true;
    setTimeout(()=>{
      btn.style.background='#0a0806';btn.style.borderColor='var(--border2)';btn.style.color='var(--text2)';
      btn.dataset.state='';quizLocked=false;
    },2000);
  }
}

function nextQuestion(){
  quizIdx++;
  if(quizIdx>=QUIZ.length){clearInterval(quizCountdown);showQuizResult(false);return;}
  document.getElementById('quiz-prog-fill').style.width=((quizIdx/20)*100)+'%';
  document.getElementById('quiz-prog-lbl').textContent='퀴즈 '+quizIdx+' / 20';
  showQuestion();
}

async function showQuizResult(timeout){
  const elapsed=parseFloat(((Date.now()-quizStart)/1000).toFixed(1));
  clearInterval(quizCountdown);
  const c=getCurrentScene();if(c>=0)sceneHistory.push(c);
  switchScene(24);
  document.getElementById('result-time').textContent=elapsed+'초';
  document.getElementById('result-score').textContent=quizCorrect+' / '+QUIZ.length+' 정답';

  const perfect=(quizCorrect===QUIZ.length);
  const epGiven=(perfect&&!timeout)?5:0;

  let msg='';
  if(timeout) msg='시간이 초과됐습니다. 다시 도전해보세요!';
  else if(perfect) msg='완벽합니다! 이성계의 시대를 꿰뚫었습니다. ✨ 환생포인트 5 획득!';
  else if(quizCorrect>=16) msg='훌륭합니다. 이성계를 깊이 이해했습니다.';
  else if(quizCorrect>=12) msg='좋습니다. 다시 도전하면 더 선명해질 거예요.';
  else msg='다시 도전해보세요. 이성계의 이야기가 기다립니다.';
  document.getElementById('result-msg').textContent=msg;

  if(!currentUser) return;

  // 퀴즈 기록 저장
  await sb.from('quiz_records').insert({
    user_id: currentUser.id,
    episode: 1,
    elapsed: elapsed,
    perfect: perfect,
    ep_given: epGiven
  });

  // EP 지급 및 환생권 체크
  if(epGiven>0){
    const{data:profile}=await sb.from('profiles')
      .select('ep_balance, rebirth_tickets')
      .eq('id',currentUser.id).single();
    if(profile){
      const newEp = profile.ep_balance + epGiven;
      const newTickets = profile.rebirth_tickets + Math.floor(newEp/100);
      const remainEp = newEp % 100;

      await sb.from('profiles').update({
        ep_balance: remainEp,
        rebirth_tickets: newTickets
      }).eq('id',currentUser.id);

      await sb.from('ep_history').insert({
        user_id: currentUser.id,
        amount: epGiven,
        reason: '태조편 퀴즈 100점 (60초 이내)'
      });

      // 환생권 획득 알림
      if(newTickets > profile.rebirth_tickets){
        const gained = newTickets - profile.rebirth_tickets;
        document.getElementById('result-msg').textContent
          += ' 🎉 환생권 '+gained+'장 획득!';
      }
    }
  }
}

// ── 에필로그 로그 ─────────────────────────────────────────
const LOG_MAP={
  0:{follow:'왕명을 따른다고 했다',defy:'왕명을 따르지 않겠다고 했다',none:'선택하지 않았다 — 때를 놓쳤다'},
  4:{a:'싸웠다 — 방법을 찾지 못했다',b:'싸우지 않았다 — 방법을 찾지 못했다'},
  8:{a:'싸웠다 — 방법을 찾지 못했다',b:'싸우지 않았다 — 방법을 찾지 못했다'},
  12:{a:'싸웠다 — 방법을 찾지 못했다',b:'싸우지 않았다 — 방법을 찾지 못했다'},
  16:{a:'따랐다 — 방법을 찾지 못했다',b:'따르지 않았다 — 방법을 찾지 못했다'},
  20:{a:'이방원을 벌했다',b:'이방원을 감쌌다',c:'모른 척했다'},
};
let picks={};
function buildEpi(){
  const lines=[];
  // 오프닝 선택
  if(opChoice&&LOG_MAP[0]&&LOG_MAP[0][opChoice])lines.push('[오프닝] '+LOG_MAP[0][opChoice]);
  [4,8,12,16,20].forEach(s=>{
    if(picks[s]&&LOG_MAP[s]&&LOG_MAP[s][picks[s]])lines.push(LOG_MAP[s][picks[s]]);
  });
  const el=document.getElementById('epi-log');
  if(el)el.innerHTML=lines.length?lines.join('<br>'):'—';
}

// ── 선택지 처리 ──────────────────────────────────────────
const WRONG_MSG={
  4:{
    a:'싸웠습니다.\n지방 호족 하나가 원나라를 이길 수 없었습니다.\n집안이 사라졌을 것입니다.\n\n이성계의 아버지는 다른 방법을 찾았습니다.',
    b:'싸우지 않았습니다.\n그냥 버티는 것이었습니다.\n기회는 오지 않았을 것입니다.\n\n이성계의 아버지는 다른 방법을 찾았습니다.',
  },
  8:{
    a:'싸웠습니다.\n정면 돌파. 2천으로 5천을 맞받아쳤습니다.\n많이 다쳤습니다. 이겼지만 값이 비쌌습니다.\n\n이성계는 다른 방법을 찾았습니다.',
    b:'싸우지 않았습니다.\n후퇴했습니다.\n그 사이 마을 세 곳이 불탔습니다.\n다른 내 사람을 잃었습니다.\n\n이성계는 다른 방법을 찾았습니다.',
  },
  12:{
    a:'싸웠습니다.\n화살이 통하지 않는 아기발도를 상대하다 시간을 잃었습니다.\n\n이성계는 다른 방법을 찾았습니다.',
    b:'싸우지 않았습니다.\n왜구가 계속 밀고 올라왔습니다.\n내 사람들이 밀렸습니다.\n\n이성계는 다른 방법을 찾았습니다.',
  },
  16:{
    a:'따랐습니다.\n진격했습니다.\n명나라군 100만 앞에 4만 8천이 무너졌습니다.\n\n이성계는 다른 방법을 찾았습니다.',
    b:'따르지 않았습니다.\n그냥 거부했습니다.\n명분이 없었습니다. 반역이 됐습니다.\n내 사람들이 역적의 가족이 됐습니다.\n\n이성계는 다른 방법을 찾았습니다.',
  },
};

const NO_ANSWER_MSG=[
  '벌했다.\n이방원을 잃었다.\n명분은 지켰다.\n그런데 — 내 사람을 벌하면 다른 내 사람을 잃는다.',
  '감쌌다.\n정몽주를 잃었다. 명분도 흔들렸다.\n힘으로 이기면 적이 쓰러진다.\n정몽주는 쓰러졌다. 사라진 것이 아니었다.\n6년 후 이방원이 다시 칼을 들었다.',
  '모른 척했다.\n아무것도 하지 않았다.\n결국 감싼 것과 같았다.\n6년 후 이방원이 다시 칼을 들었다.',
];

function tryPick(scene, choice, answer){
  picks[scene]=choice;
  const btnId='g'+scene+choice;
  const btn=document.getElementById(btnId);
  if(!btn)return;

  if(answer==='x'){
    // 둘 다 선택 가능 — 결과 보여주고 버튼으로 넘어가기
    const msg=WRONG_MSG[scene]&&WRONG_MSG[scene][choice];
    ['a','b','c'].forEach(c=>{
      const b=document.getElementById('g'+scene+c);
      if(b&&c!==choice)b.classList.add('blocked');
    });
    btn.classList.add('iseonggye');
    const bmEl=document.getElementById('bm'+scene);
    const textEl=document.getElementById('bm'+scene+'-text');
    if(bmEl){
      // 기존 동적 버튼 제거 후 새로 추가
      const oldBtn=bmEl.querySelector('button.next-btn');
      if(oldBtn)oldBtn.remove();
      if(textEl)textEl.innerHTML=msg?msg.replace(/\n/g,'<br>'):'';
      const nextBtn=document.createElement('button');
      nextBtn.innerHTML=scene===4?'이자춘은 어떻게 했을까 →':'이성계는 어떻게 했을까 →';
      nextBtn.className='next-btn';
      nextBtn.style.cssText='margin-top:10px;background:#0c0804;border:1px solid #3a2008;border-radius:4px;padding:8px 16px;color:#c09040;font-size:13px;cursor:pointer;font-family:\'Noto Serif KR\',serif;display:block;width:100%;';
      nextBtn.onclick=()=>go(scene+1);
      bmEl.classList.add('on');
      bmEl.appendChild(nextBtn);
    }
    return;
  }

  if(choice===answer){
    // 정답
    ['a','b','c'].forEach(c=>{
      const b=document.getElementById('g'+scene+c);
      if(b&&c!==choice){b.classList.add('blocked');}
    });
    btn.classList.add('iseonggye');
    setTimeout(()=>go(scene+1),700);
  } else {
    // 오답
    const msg=WRONG_MSG[scene]&&WRONG_MSG[scene][choice];
    if(msg){
      btn.classList.add('wrong-shake');
      setTimeout(()=>btn.classList.remove('wrong-shake'),400);
      const bmEl=document.getElementById('bm'+scene);
      const textEl=document.getElementById('bm'+scene+'-text');
      if(textEl)textEl.innerHTML=msg.replace(/\n/g,'<br>');
      if(bmEl)bmEl.classList.add('on');
    }
  }
}

function resetBlock(scene){
  ['a','b','c'].forEach(c=>{
    const b=document.getElementById('g'+scene+c);
    if(b){b.classList.remove('blocked','iseonggye','wrong-shake');}
  });
  const bm=document.getElementById('bm'+scene);
  if(bm){
    bm.classList.remove('on');
    // 동적으로 추가된 버튼 제거
    const dynBtn=bm.querySelector('button[onclick]');
    if(dynBtn)dynBtn.remove();
  }
  delete picks[scene];
}

// ── 4막 정답없음 처리 ────────────────────────────────────
let pick4Done=false;
function pick4(idx){
  if(pick4Done)return;
  picks[20]=['a','b','c'][idx];
  const ids=['g20a','g20b','g20c'];
  ids.forEach((id,i)=>{
    const b=document.getElementById(id);
    if(b&&i!==idx)b.classList.add('blocked');
  });
  const selected=document.getElementById(ids[idx]);
  if(selected)selected.classList.add('iseonggye');
  const nam=document.getElementById('nam');
  const nan=document.getElementById('nan');
  const txt=document.getElementById('nam-text');
  if(txt)txt.innerHTML=NO_ANSWER_MSG[idx].replace(/\n/g,'<br>');
  if(nam)nam.classList.add('on');
  setTimeout(()=>{if(nan)nan.classList.add('on');},600);
  pick4Done=true;
}

// ── 타이핑 ───────────────────────────────────────────────
const NARR={
  2:'쌍성.\n원나라의 지배를 받고 있는 고려의 땅.\n\n고려인으로 살아남기\n너무 팍팍하다.',
  6:'스물여섯.\n\n처음이다.\n명령을 받은 것이 아니라\n내가 명령을 내려야 한다.\n\n2천 명이 나를 올려다보고 있다.',
  10:'마흔다섯.\n\n왜구 10만이 전라도에 상륙했다.\n아군은 5천.\n\n소년 장수 아기발도가 이끌고 있다.',
  14:'쉰셋.\n\n왕명이 내려왔다.\n요동 정벌.\n병사 4만 8천.\n\n이성계는 사불가론을 올렸다.\n그러나 묵살됐다.',
  18:'쉰일곱.\n\n조선이 거의 다 왔다.\n\n그런데 이성계가 말에서 떨어졌다.\n정몽주가 그 틈을 이용했다.',
};
const NARR_NAV={2:'nav2',6:'nav6',10:'nav10',14:'nav14',18:'nav18'};
let typingTimers=[],sceneToken=0;
const SPD=44;

function typeText(id,text,onDone){
  typingTimers.forEach(clearTimeout);typingTimers=[];
  const el=document.getElementById(id);if(!el)return;
  el.innerHTML='';let i=0;const tok=sceneToken;
  function tick(){
    if(tok!==sceneToken)return;
    if(i>=text.length){
      el.innerHTML=el.innerHTML.replace('<span class="cursor"></span>','');
      if(onDone)setTimeout(()=>{if(tok===sceneToken)onDone();},300);return;
    }
    const ch=text[i];
    el.innerHTML=el.innerHTML.replace('<span class="cursor"></span>','')
      +(ch==='\n'?'<br>':ch)+'<span class="cursor"></span>';
    i++;
    const d=ch==='\n'?SPD*5:ch==='.'||ch==='?'||ch==='!'?SPD*4:ch===','?SPD*2:SPD;
    typingTimers.push(setTimeout(tick,d));
  }
  tick();
}

// ── 환생 ─────────────────────────────────────────────────
const RB=[
  {text:'1335년',hold:1500},
  {text:'함경도 화령.',cls:'dim',hold:1500},
  {text:'지금부터 — 당신이 이성계다.',cls:'final',hold:2400,last:true},
];
let rbTimers=[];
function startRebirth(){
  switchScene(1);rbTimers.forEach(clearTimeout);rbTimers=[];
  const stage=document.getElementById('rb-stage'),portal=document.getElementById('rb-portal'),cta=document.getElementById('rb-cta');
  if(stage)stage.innerHTML='';if(cta)cta.style.opacity='0';if(portal)portal.classList.remove('show');
  setTimeout(()=>{
    if(portal)setTimeout(()=>portal.classList.add('show'),200);
    const FI=900,FO=600;let cur=500;
    RB.forEach(step=>{
      const el=document.createElement('div');
      el.className='rb-word'+(step.cls?' '+step.cls:'');
      el.textContent=step.text;el.style.cssText='opacity:0;transition:opacity '+(FI/1000)+'s ease;';
      if(stage)stage.appendChild(el);const ref=el;
      rbTimers.push(setTimeout(()=>{ref.style.opacity='1';},cur));
      if(!step.last){
        rbTimers.push(setTimeout(()=>{ref.style.transition='opacity '+(FO/1000)+'s ease';ref.style.opacity='0';setTimeout(()=>{if(ref.parentNode)ref.parentNode.removeChild(ref);},FO);},cur+FI+step.hold));
        cur+=FI+step.hold+FO;
      } else {
        cur+=FI+step.hold;
        rbTimers.push(setTimeout(()=>{if(cta){cta.style.transition='opacity 1s ease';cta.style.opacity='1';}},cur+300));
      }
    });
  },400);
}

// ── 후기 전송 ────────────────────────────────────────────
async function submitReview(){
  const body=document.getElementById('rv-body').value.trim();
  if(!body){alert('후기 내용을 입력해주세요.');return;}

  const sentEl=document.getElementById('rv-sent');

  // Supabase에 저장
  if(currentUser){
    await sb.from('reviews').insert({
      user_id: currentUser.id,
      episode: 1,
      content: body
    });

    // EP +10 지급
    const{data:profile}=await sb.from('profiles')
      .select('ep_balance,rebirth_tickets').eq('id',currentUser.id).single();
    if(profile){
      const newEp=profile.ep_balance+10;
      const newTickets=profile.rebirth_tickets+Math.floor(newEp/100);
      const remainEp=newEp%100;
      await sb.from('profiles')
        .update({ep_balance:remainEp,rebirth_tickets:newTickets})
        .eq('id',currentUser.id);
      await sb.from('ep_history').insert({
        user_id:currentUser.id,amount:10,reason:'태조편 후기 작성'
      });
      const msg=newTickets>profile.rebirth_tickets
        ?'✓ 후기 감사합니다! ✨ EP +10 · 🎟 환생권 '+newTickets+'장!'
        :'✓ 후기 감사합니다! ✨ 환생포인트 +10 지급!';
      sentEl.textContent=msg;
    }
  } else {
    // 비로그인 - 그냥 저장만 (익명)
    await sb.from('reviews').insert({episode:1,content:body});
    sentEl.textContent='✓ 후기가 전달됐습니다. 감사합니다!';
  }

  sentEl.style.display='block';
  document.getElementById('rv-body').value='';
  document.getElementById('rv-nick').value='';
}

// ── 메뉴 ─────────────────────────────────────────────────
let forwardHistory=[];
function toggleMenu(){document.getElementById('menu-drop')?.classList.toggle('open');}
function closeMenu(){document.getElementById('menu-drop')?.classList.remove('open');}
function menuGoBack(){closeMenu();goBack();}
function menuGoForward(){
  closeMenu();if(!forwardHistory.length)return;
  const n=forwardHistory.pop();
  const c=getCurrentScene();if(c>=0)sceneHistory.push(c);
  switchScene(n);
}
function menuReload(){closeMenu();const c=getCurrentScene();if(c>=0)switchScene(c);}
function menuGo(n){closeMenu();go(n);}
document.addEventListener('click',e=>{
  const mw=document.querySelector('.menu-wrap');
  if(mw&&!mw.contains(e.target))closeMenu();
});

// ── switchScene ──────────────────────────────────────────
let sceneHistory=[];
function go(n){forwardHistory=[];const c=getCurrentScene();if(c>=0)sceneHistory.push(c);switchScene(n);}
function goBack(){if(!sceneHistory.length){switchScene(0);return;}const c=getCurrentScene();if(c>=0)forwardHistory.push(c);switchScene(sceneHistory.pop());}
function getCurrentScene(){const on=document.querySelector('.sc.on');return on?parseInt(on.id.replace('s','')):-1;}

function switchScene(n){
  sceneToken++;typingTimers.forEach(clearTimeout);typingTimers=[];rbTimers.forEach(clearTimeout);rbTimers=[];
  if(opTimerInterval){clearInterval(opTimerInterval);opTimerInterval=null;}
  if(n!==23&&n!==24){clearInterval(quizTimer);}

  // 모든 씬 숨기기
  document.querySelectorAll('.sc').forEach(s=>{
    s.classList.remove('on');
    s.style.display='none';
    s.style.opacity='0';
    s.style.transition='none';
  });

  const t=document.getElementById('s'+n);if(!t)return;
  t.style.display='flex';
  t.style.flexDirection='column';
  t.style.opacity='0';
  t.classList.add('on');

  // 페이지 최상단으로 스크롤
  window.scrollTo(0,0);
  document.documentElement.scrollTop=0;
  document.body.scrollTop=0;

  requestAnimationFrame(()=>requestAnimationFrame(()=>{t.style.transition='opacity 0.35s ease';t.style.opacity='1';}));

  document.querySelectorAll('.btn-back,.menu-wrap').forEach(b=>b.remove());
  if(n>0){
    const menuWrap=document.createElement('div');
    menuWrap.className='menu-wrap';
    menuWrap.innerHTML=`
      <button class="menu-btn" onclick="toggleMenu()">⋯</button>
      <div class="menu-drop" id="menu-drop">
        <button class="menu-item" onclick="menuGoBack()">← 이전으로</button>
        <button class="menu-item" onclick="menuGoForward()">→ 앞으로</button>
        <button class="menu-item" onclick="menuReload()">↺ 현재 페이지 다시보기</button>
        <div class="menu-divider"></div>
        <div class="menu-section">막 이동</div>
        <button class="menu-item" onclick="menuGo(2)">0막 · 때를 기다린다</button>
        <button class="menu-item" onclick="menuGo(6)">1막 · 싸운다</button>
        <button class="menu-item" onclick="menuGo(10)">2막 · 함께 싸운다</button>
        <button class="menu-item" onclick="menuGo(14)">3막 · 명분을 만든다</button>
        <button class="menu-item" onclick="menuGo(18)">4막 · 정답이 없다</button>
        <div class="menu-divider"></div>
        <button class="menu-item" onclick="location.href='../joseon-kings.html'">📜 왕 선택 화면</button>
        <button class="menu-item" onclick="location.href='../index.html'">🏠 처음 화면</button>
      </div>`;
    document.body.appendChild(menuWrap);
  }

  if(n===0){
    setTimeout(runOpeningAnim,300);
    opChoice=null;
    const area=document.getElementById('op-choice-area');
    if(area){area.style.opacity='0';}
    const num=document.getElementById('op-timer-num');
    if(num)num.textContent='10';
    const btnFollow=document.getElementById('op-btn-follow');
    const btnDefy=document.getElementById('op-btn-defy');
    if(btnFollow){btnFollow.style.borderColor='var(--border2)';btnFollow.style.color='var(--text2)';}
    if(btnDefy){btnDefy.style.borderColor='var(--border2)';btnDefy.style.color='var(--text2)';}
  }
  if(NARR[n]){
    const navId=NARR_NAV[n];
    const navEl=document.getElementById(navId);
    if(navEl)navEl.style.display='none';
    const narrEl=document.getElementById('narr'+n);
    if(narrEl)narrEl.innerHTML='';
    setTimeout(()=>{
      typeText('narr'+n,NARR[n],()=>{
        if(navEl){navEl.style.display='flex';navEl.style.animation='fi .4s ease';}
      });
    },400);
  }
  if([4,8,12,16].includes(n))resetBlock(n);
  if(n===20){pick4Done=false;['a','b','c'].forEach(c=>{const b=document.getElementById('g20'+c);if(b)b.classList.remove('blocked','iseonggye');});document.getElementById('nam')?.classList.remove('on');document.getElementById('nan')?.classList.remove('on');}
  if(n===22)buildEpi();

  const deep=[5,9,13,17,21].includes(n);
  const drone=[2,3,4,5,6,7,8,9,22].includes(n);
  if(!deep)stopDeep();if(!drone)stopDrone();
  if(deep)setTimeout(startDeep,500);if(drone)setTimeout(startDrone,500);
}

// ── 오프닝 타이머 ────────────────────────────────────────
let opTimerInterval=null;
let opChoice=null;

function opChoose(choice){
  if(opTimerInterval){clearInterval(opTimerInterval);opTimerInterval=null;}
  opChoice=choice;
  // 선택한 버튼 표시
  const btnFollow=document.getElementById('op-btn-follow');
  const btnDefy=document.getElementById('op-btn-defy');
  if(choice==='follow'&&btnFollow){btnFollow.style.borderColor='var(--gold3)';btnFollow.style.color='var(--gold3)';}
  if(choice==='defy'&&btnDefy){btnDefy.style.borderColor='var(--gold3)';btnDefy.style.color='var(--gold3)';}
  setTimeout(()=>startRebirth(),600);
}

function startOpTimer(){
  const area=document.getElementById('op-choice-area');
  const num=document.getElementById('op-timer-num');
  if(!area||!num)return;
  requestAnimationFrame(()=>requestAnimationFrame(()=>{area.style.opacity='1';}));

  let remaining=10;
  num.textContent=remaining;

  opTimerInterval=setInterval(()=>{
    remaining--;
    if(num)num.textContent=remaining;
    if(remaining<=0){
      clearInterval(opTimerInterval);opTimerInterval=null;
      // 시간이 다 돼도 페이지 넘기지 않음 — 선택을 기다린다
      if(num)num.textContent='...';
    }
  },1000);
}

// ── 오프닝 애니메이션 ────────────────────────────────────
function runOpeningAnim(){
  const ids=['op-question','op-glyph','op-series','op-disc'];
  const els=ids.map(id=>document.getElementById(id));
  els.forEach(el=>{if(el){el.style.transition='none';el.style.opacity='0';}});
  const area=document.getElementById('op-choice-area');
  if(area){area.style.opacity='0';}

  requestAnimationFrame(()=>{
    // 1. 질문 3줄 등장
    if(els[0]){els[0].style.transition='opacity 1.6s ease';els[0].style.opacity='1';}
    // 2. 질문과 동시에 선택지도 등장
    setTimeout(()=>startOpTimer(),800);
    // 3. 글리프
    setTimeout(()=>{if(els[1]){els[1].style.transition='opacity 1.4s ease';els[1].style.opacity='1';}},2000);
    // 4. 시리즈
    setTimeout(()=>{if(els[2]){els[2].style.transition='opacity 1.4s ease';els[2].style.opacity='1';}},3200);
    // 5. 주석
    setTimeout(()=>{if(els[3]){els[3].style.transition='opacity 1.4s ease';els[3].style.opacity='1';}},4000);
  });
}

// ── 사운드 ───────────────────────────────────────────────
let droneCtx=null,droneGain=null;
function createDrone(){if(droneCtx)return;droneCtx=new(window.AudioContext||window.webkitAudioContext)();droneGain=droneCtx.createGain();droneGain.gain.value=0;droneGain.connect(droneCtx.destination);[55,110].forEach(f=>{const o=droneCtx.createOscillator(),g=droneCtx.createGain();o.type='sine';o.frequency.value=f;g.gain.value=0.1;o.connect(g);g.connect(droneGain);o.start();});}
function startDrone(){createDrone();if(droneCtx.state==='suspended')droneCtx.resume();droneGain.gain.cancelScheduledValues(droneCtx.currentTime);droneGain.gain.setValueAtTime(droneGain.gain.value,droneCtx.currentTime);droneGain.gain.linearRampToValueAtTime(0.26,droneCtx.currentTime+8);}
function stopDrone(){if(!droneCtx||!droneGain)return;const c=droneCtx.currentTime,v=droneGain.gain.value;droneGain.gain.cancelScheduledValues(c);droneGain.gain.setValueAtTime(v,c);droneGain.gain.linearRampToValueAtTime(0,c+(v<0.05?0.3:8));}
let deepCtx=null,deepGain=null;
function createDeep(){if(deepCtx)return;deepCtx=new(window.AudioContext||window.webkitAudioContext)();deepGain=deepCtx.createGain();deepGain.gain.value=0;deepGain.connect(deepCtx.destination);[40,80].forEach(f=>{const o=deepCtx.createOscillator(),g=deepCtx.createGain();o.type='sine';o.frequency.value=f;g.gain.value=0.07;o.connect(g);g.connect(deepGain);o.start();});}
function startDeep(){createDeep();if(deepCtx.state==='suspended')deepCtx.resume();deepGain.gain.cancelScheduledValues(deepCtx.currentTime);deepGain.gain.setValueAtTime(deepGain.gain.value,deepCtx.currentTime);deepGain.gain.linearRampToValueAtTime(0.2,deepCtx.currentTime+10);}
function stopDeep(){if(!deepCtx||!deepGain)return;const c=deepCtx.currentTime,v=deepGain.gain.value;deepGain.gain.cancelScheduledValues(c);deepGain.gain.setValueAtTime(v,c);deepGain.gain.linearRampToValueAtTime(0,c+(v<0.05?0.3:10));}

window.addEventListener('load',()=>{
  // 모든 씬 숨기고 s0만 표시
  document.querySelectorAll('.sc').forEach(s=>{
    s.style.display='none';
    s.style.opacity='0';
  });
  const s0=document.getElementById('s0');
  if(s0){
    s0.style.display='flex';
    s0.style.flexDirection='column';
    s0.style.opacity='1';
    s0.classList.add('on');
  }
  setTimeout(runOpeningAnim,300);
});
</script>
</body>
</html>
